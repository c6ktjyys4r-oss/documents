# Environment Variables — Alba Documents
    #
    # This file documents all environment variables required by the Documents application.
    # Copy this file to .env and fill in the values. Never commit .env to version control.
    #
    # ─────────────────────────────────────────────────────────────
    # DATABASE
    # ─────────────────────────────────────────────────────────────

    # Neon PostgreSQL connection string.
    # Neon project: alba-documents (cool-sun-76918389)
    # Region: aws-eu-central-1
    # Obtain from: https://console.neon.tech/app/projects/cool-sun-76918389
    DATABASE_URL=postgresql://<user>:<password>@<host>/neondb?sslmode=require

    # ─────────────────────────────────────────────────────────────
    # NOTES
    # ─────────────────────────────────────────────────────────────
    # - The current application is a static site and does not use DATABASE_URL at runtime.
    # - DATABASE_URL is pre-configured in the Render deployment environment.
    # - Set this variable when adding a backend service to this project.
    